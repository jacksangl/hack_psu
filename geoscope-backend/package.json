{
  "name": "geoscope-backend",
  "version": "1.0.0",
  "private": true,
  "packageManager": "bun@1.3.8",
  "description": "GeoScope backend API for country news, briefs, sentiment, and comparison.",
  "scripts": {
    "dev": "bun --watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "bun dist/src/index.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "cheerio": "^1.2.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.2",
    "express-rate-limit": "^7.5.0",
    "helmet": "^8.0.0",
    "i18n-iso-countries": "^7.13.0",
    "pg": "^8.20.0",
    "redis": "^4.7.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^22.10.2",
    "@types/pg": "^8.20.0",
    "@types/supertest": "^6.0.3",
    "pg-mem": "^3.0.14",
    "supertest": "^7.0.0",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
